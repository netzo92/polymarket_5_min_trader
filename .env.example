POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_MARKET_LIMIT=500
# Live late-leader runs should poll faster than the entry window.
POLYMARKET_SCAN_INTERVAL_SECONDS=5
POLYMARKET_MIN_MINUTES_TO_EXPIRY=2
POLYMARKET_MAX_MINUTES_TO_EXPIRY=8
POLYMARKET_TARGET_MINUTES_TO_EXPIRY=5
POLYMARKET_MIN_LIQUIDITY=5000
POLYMARKET_MAX_SPREAD=0.08
POLYMARKET_MIN_MIDPOINT=0.10
POLYMARKET_MAX_MIDPOINT=0.90
POLYMARKET_MOMENTUM_WINDOW_MINUTES=3
POLYMARKET_MIN_OBSERVATIONS=3
POLYMARKET_MIN_EDGE=0.015
# Runtime strategy choices are the non-backtest strategies from README.
POLYMARKET_STRATEGY=late_leader
# Current best live-like horizon from the BTC 5-minute backtests.
POLYMARKET_LATE_LEADER_HORIZON_SECONDS=39
# The live late-leader entry band now follows POLYMARKET_SCAN_INTERVAL_SECONDS.
# This legacy setting is kept for compatibility but no longer widens the live window.
POLYMARKET_LATE_LEADER_WINDOW_SECONDS=5
# Safer live starting size for a small bankroll.
POLYMARKET_ORDER_AMOUNT=5
# Optional dynamic sizing. Set to 1 for 1% of current collateral balance.
# When greater than 0, this overrides POLYMARKET_ORDER_AMOUNT.
POLYMARKET_ORDER_SIZE_PCT=0
# Optional kill switch. Set to 0 to disable, or a small positive integer such as 3
# to stop the bot after that many consecutive settled losses.
POLYMARKET_MAX_CONSECUTIVE_LOSSES=0
POLYMARKET_RECENT_TRADE_COOLDOWN_MINUTES=20
POLYMARKET_STATE_PATH=data/state.json
POLYMARKET_LOCK_PATH=data/live.lock
POLYMARKET_LOG_PATH=data/bot.log
POLYMARKET_LOG_BACKUP_COUNT=5
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
# Safe-only: when true, redeem settled winning positions through the Polymarket relayer.
POLYMARKET_AUTO_CLAIM_WINNERS=false

# Default mode: paperless dry run against live markets.
POLYMARKET_DRY_RUN=true
POLYMARKET_LIVE_ENABLED=false

# Live trading supports two wallet modes.
#
# Standalone EOA wallet:
# 1. Set POLYMARKET_PRIVATE_KEY to your Polygon/EVM wallet private key.
# 2. Keep POLYMARKET_SIGNATURE_TYPE=0 (EOA).
# 3. Leave POLYMARKET_FUNDER_ADDRESS blank.
# 4. Fund that same wallet with the trading collateral and Polygon gas.
# 5. Leave the API creds blank unless you already have them; the bot can derive them.
# 6. Flip POLYMARKET_DRY_RUN=false and POLYMARKET_LIVE_ENABLED=true only when ready.
# 7. Run `polymarket-5m-bot doctor --verbose` before the first live session.
#
# Polymarket.com proxy/Safe wallet:
# - Log in to Polymarket.com once first so the proxy wallet exists before trading.
# - Set POLYMARKET_SIGNATURE_TYPE to 1 (POLY_PROXY) or 2 (GNOSIS_SAFE).
# - Set POLYMARKET_FUNDER_ADDRESS to the proxy wallet address shown by Polymarket.
# - If this is the first live trade for that wallet, complete the one-time
#   Exchange approval in the Polymarket UI first.
# - Keep the private key local and never commit a real .env file.
#
# Availability also depends on jurisdiction. If Polymarket blocks trading in your
# region, keep the bot in dry-run mode.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Optional Builder relayer creds used by Safe auto-claim. If left blank, the bot
# will fall back to POLYMARKET_API_* above.
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
